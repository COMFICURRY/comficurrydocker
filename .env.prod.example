# Copy to .env (in this folder) and fill in, then:
#   docker compose -f docker-compose.prod.yml up -d --build

# The VM's reachable API URL — BAKED INTO THE FRONTENDS AT BUILD TIME.
# Use the public IP/domain the CEO's browser will hit, NOT localhost.
#   e.g. http://203.0.113.10:8080   or   https://api.yourdomain.com
PUBLIC_API_URL=http://CHANGE_ME:8080

# Database (internal to the compose network)
POSTGRES_USER=comficurry
POSTGRES_PASSWORD=change-this-strong-password
POSTGRES_DB=comficurry

# JWT signing secret (any long random string)
JWT_SECRET_KEY=change-this-to-a-long-random-string

# LINE — optional for the prototype. Guest login bypasses LINE, and the
# "send order to LINE" call fails quietly if these are placeholders. Set real
# values only if you want LINE order messages.
LINE_CHANNEL_TOKEN=prototype-placeholder-token
LINE_CHANNEL_SECRET=prototype-placeholder-secret
